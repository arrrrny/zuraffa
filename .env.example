# Zuraffa Configuration (.env)
#
# Copy this file to .env in your project root to configure Zuraffa behavior.
# All settings are optional with sensible defaults.

# ==========================================
# ENFORCE_ID - Strict ID validation
# ==========================================
# If true, ALL entities MUST have an id field (no auto-detection)
# If false (default), entities without id become Value Objects automatically
#
# Default: false (recommended - allows Value Objects)
# ENFORCE_ID=false

# ==========================================
# AUTO_DETECT - Auto-detect Entities vs Value Objects
# ==========================================
# If true (default), Zuraffa automatically detects based on id field presence:
#   - JSON with id → Entity (full CRUD stack)
#   - JSON without id → Value Object (just entity + tests)
#
# If false, all generated types are treated as specified (--value-object flag required)
#
# Default: true (recommended - AI-First behavior)
# AUTO_DETECT=true

# ==========================================
# DEFAULT_ID_TYPE - Preferred id field type
# ==========================================
# Preferred type for id fields when generating examples/docs
# Options: String | int
#
# Default: String
# DEFAULT_ID_TYPE=String

# ==========================================
# Example Configurations
# ==========================================

# Strict mode (no auto-detection, all must have id):
# ENFORCE_ID=true
# AUTO_DETECT=false

# Flexible mode (default - auto-detect everything):
# ENFORCE_ID=false
# AUTO_DETECT=true

# Custom: Allow Value Objects but prefer int ids in examples:
# ENFORCE_ID=false
# AUTO_DETECT=true
# DEFAULT_ID_TYPE=int
